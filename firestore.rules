rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — any authenticated user can read; owner can write (but cannot set isAdmin via client)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // Jobs — any authenticated user can read; creator (clientId) can update/delete
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.clientId;
    }

    // Proposals — anyone logged in can create; client or freelancer can read/update
    match /proposals/{proposalId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.freelancerId ||
        request.auth.uid == resource.data.clientId
      );
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.clientId ||
        request.auth.uid == resource.data.freelancerId
      );
    }

    // Wallets — owner can always read their own wallet.
    // Write is relaxed for all authenticated users to support client-side escrow
    // release crediting the freelancer's wallet (no Cloud Functions on free tier).
    // TODO: Move wallet mutations to a Cloud Function before production launch.
    match /wallets/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;

      // Transaction history subcollection — only the wallet owner can read/write
      match /transactions/{txId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // Contracts — client or freelancer can read/update; any authenticated user can create
    match /contracts/{contractId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (
        request.auth.uid == resource.data.clientId ||
        request.auth.uid == resource.data.freelancerId
      );
    }

    // Messages & Threads — authenticated users only
    match /threads/{threadId} {
      allow read, write: if request.auth != null;
    }
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Notifications — any authenticated user can create (for system cross-user notifications);
    // only the owner can read, update, or delete their own notifications
    match /notifications/{notifId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // Reviews — anyone can read/create; only author can update or delete
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.fromId;
    }

    // Disputes — anyone can read/create; only original filer or an admin can update
    match /disputes/{disputeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

  }
}